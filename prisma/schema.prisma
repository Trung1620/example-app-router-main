datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Version: 2024-04-21-FIX-SCHEMA
// ==========================================
// 1. QUẢN LÝ DOANH NGHIỆP & NGƯỜI DÙNG
// ==========================================

enum Role {
  USER
  ADMIN
  MODERATOR
  MANAGER
  STAFF
}

enum OrgRole {
  OWNER
  ADMIN
  STAFF
}

model Org {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh
  code            String?  @unique // Mã định danh xưởng (vd: "trangbamboo")
  name            String // Tên xưởng sản xuất
  taxId           String? // Mã số thuế
  address         String? // Địa chỉ trụ sở
  phone           String? // Số điện thoại liên hệ
  email           String? // Email doanh nghiệp
  logo            String? // Đường dẫn ảnh Logo
  website         String? // Website doanh nghiệp
  description     String? // Mô tả ngắn về xưởng
  
  bankName        String? // Tên ngân hàng
  bankAccount     String? // Số tài khoản ngân hàng
  bankOwner       String? // Chủ tài khoản ngân hàng
  directorName    String? // Tên người đại diện pháp luật
  businessLicense String? // Số giấy phép kinh doanh

  createdAt DateTime @default(now()) // Ngày tạo
  updatedAt DateTime @updatedAt // Ngày cập nhật cuối

  members OrgMember[] // Danh sách thành viên thuộc xưởng

  products      Product[] // Danh sách sản phẩm của xưởng
  customers     Customer[] // Danh sách khách hàng của xưởng
  suppliers     Supplier[] // Danh sách nhà cung cấp
  quotes        Quote[] // Danh sách báo giá/đơn hàng
  deliveries    Delivery[] // Danh sách phiếu giao hàng

  warehouses     Warehouse[] // Danh sách kho hàng
  stockMoves     StockMove[] // Lịch sử nhập/xuất kho
  stockMoveItems StockMoveItem[] // Chi tiết các dòng nhập/xuất kho
  stockBalances  StockBalance[] // Số dư tồn kho thực tế

  productVariants   ProductVariant[] // Các biến thể sản phẩm (size, màu...)
  debts             Debt[] // Quản lý công nợ
  reports           Report[] // Danh sách báo cáo đã lưu
  notifications     Notification[] // Thông báo hệ thống

  materials           Material[] // Danh sách nguyên vật liệu
  categories          Category[] // Danh mục sản phẩm/vật tư
  artisans            Artisan[] // Danh sách nghệ nhân/thợ
  artisanAttendances  ArtisanAttendance[] // Dữ liệu điểm danh thợ
  artisanTransactions ArtisanTransaction[] // Lịch sử ứng lương/trả lương thợ
  productionOrders    ProductionOrder[] // Lệnh sản xuất
  expenses            Expense[] // Phiếu chi tiền
  warranties          Warranty[] // Danh sách bảo hành & sửa chữa
  jobSheets           JobSheet[] // Phiếu gia công thợ
  productionProgress  ProductionProgress[] // Theo dõi tiến độ thợ làm
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh người dùng
  name           String? // Họ và tên
  email          String?   @unique // Email đăng nhập (Duy nhất)
  phone          String? // Số điện thoại
  address        String? // Địa chỉ liên hệ
  bio            String? // Giới thiệu ngắn
  avatar         String? // URL ảnh đại diện
  emailVerified  DateTime? // Ngày xác thực email
  hashedPassword String? // Mật khẩu đã mã hóa
  role           Role      @default(USER) // Vai trò người dùng (ADMIN, STAFF...)
  status         Boolean   @default(true) // Trạng thái: Đang hoạt động (true) / Khóa (false)
  
  lastLoginAt      DateTime? // Lịch sử đăng nhập cuối
  resetToken       String? // Mã khôi phục mật khẩu
  resetTokenExpiry DateTime? // Thời hạn của mã khôi phục

  createdAt      DateTime  @default(now()) // Ngày tạo tài khoản
  updatedAt      DateTime? @updatedAt @map("updatedAt") // Ngày cập nhật thông tin

  accounts Account[] // Liên kết tài khoản mạng xã hội
  sessions Session[] // Các phiên đăng nhập
  orgMembers OrgMember[] // Liên kết với các xưởng (Org)
  createdExpenses Expense[] @relation("ExpenseCreator") // Các phiếu chi do user này tạo
}

model OrgMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh thành viên xưởng
  orgId     String   @db.ObjectId // ID xưởng
  userId    String   @db.ObjectId // ID người dùng
  role      OrgRole  @default(OWNER) // Vai trò trong xưởng (Chủ xưởng, Admin, Nhân viên)
  createdAt DateTime @default(now()) // Ngày tham gia xưởng

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

// ==========================================
// 2. QUẢN LÝ NGHỆ NHÂN & SẢN XUẤT
// ==========================================

enum ArtisanStatus {
  ACTIVE
  RESIGNED
}

model Artisan {
  id    String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh thợ
  orgId String @db.ObjectId // Thuộc xưởng nào
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  code    String? @unique // Mã nhân sự (vd: THO-001)
  name    String // Họ tên thợ
  phone   String? // Số điện thoại
  address String? // Địa chỉ liên hệ
  age     Int? // Tuổi
  role    String? // Vị trí (Thợ đan, Thợ sơn...)
  image   String? // Ảnh chân dung

  skills       String? // Sở trường/kỹ năng chuyên môn
  dailyWage    Float    @default(0) // Lương theo ngày thực tế
  baseSalary   Float    @default(0) // Lương cứng thỏa thuận hàng tháng
  dailyTarget  Int      @default(0) // Định mức sản phẩm cần làm mỗi ngày
  debt         Float    @default(0) // Số tiền thợ đang nợ xưởng (ứng trước)
  status       ArtisanStatus @default(ACTIVE) // Trạng thái: Đang làm (ACTIVE) / Đã nghỉ (RESIGNED)
  isWorking    Boolean  @default(false) // Trạng thái đi làm thực tế hôm nay

  createdAt DateTime @default(now()) // Ngày tạo hồ sơ
  updatedAt DateTime @updatedAt // Ngày cập nhật cuối

  attendances      ArtisanAttendance[] // Dữ liệu điểm danh
  transactions     ArtisanTransaction[] // Lịch sử tài chính của thợ
  productionOrders ProductionOrder[] // Các lệnh sản xuất được giao
  productionWork   ProductionWorker[] // Các công việc được giao trong lệnh SX
  jobSheets        JobSheet[] // Các phiếu gia công được giao
  debts            Debt[] // Các khoản công nợ của thợ

  @@index([orgId])
}

model ArtisanTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh giao dịch thợ
  orgId     String   @db.ObjectId // ID xưởng
  artisanId String   @db.ObjectId // ID thợ
  
  type      String // Loại giao dịch (ADVANCE-Ứng lương, SALARY-Trả lương...)
  amount    Float // Số tiền giao dịch
  date      DateTime @default(now()) // Ngày thực hiện
  note      String? // Ghi chú chi tiết

  artisan Artisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([artisanId])
}

model ArtisanAttendance {
  id        String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh điểm danh
  orgId     String @db.ObjectId // ID xưởng
  artisanId String @db.ObjectId // ID thợ

  date   DateTime @default(now()) // Ngày điểm danh
  status String   @default("PRESENT") // Trạng thái: Có mặt (PRESENT), Vắng (ABSENT)...
  note   String? // Ghi chú (vd: đi muộn, về sớm)

  artisan Artisan @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, date])
  @@index([artisanId])
}

// ==========================================
// 3. QUẢN LÝ SẢN PHẨM & NGUYÊN LIỆU
// ==========================================

enum CategoryType {
  PRODUCT
  MATERIAL
}

model Category {
  id    String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh danh mục
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name        String // Tên danh mục (vd: Giỏ mây, Tre nguyên liệu)
  type        CategoryType @default(PRODUCT) // Loại: Sản phẩm (PRODUCT) hoặc Vật tư (MATERIAL)
  description String? // Mô tả chi tiết danh mục
  parentID    String? @db.ObjectId // ID danh mục cha (Phân cấp đa tầng)
  
  products    Product[] // Danh sách sản phẩm thuộc nhóm này
  materials   Material[] // Danh sách vật tư thuộc nhóm này
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
}

model Product {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh sản phẩm
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  categoryId String?   @db.ObjectId // Thuộc danh mục nào
  category   Category? @relation(fields: [categoryId], references: [id])

  nameVi        String? // Tên tiếng Việt
  sku           String?  @unique // Mã quản lý kho (Duy nhất)
  barcode       String? // Mã vạch (quét scanner)
  nameEn        String? // Tên tiếng Anh
  descriptionVi String? // Mô tả tiếng Việt
  descriptionEn String? // Mô tả tiếng Anh
  
  priceVnd      Float? // Giá bán lẻ VND
  priceUsd      Float? // Giá bán lẻ USD
  costPriceVnd  Float? // Giá vốn dự kiến
  promotionPrice Float? // Giá khuyến mãi (nếu có)
  includedVAT    Boolean @default(false) // Đã bao gồm VAT chưa
  
  unit           String? @default("cái") // Đơn vị tính (cái, bộ, chiếc...)
  weight         Float? // Khối lượng sản phẩm (kg)
  size           String? // Kích thước (DxRxC)
  brand          String? // Thương hiệu/Nhãn hiệu
  productionTime Int? // Thời gian sản xuất dự kiến (phút)
  
  materialDetails Json? // Công thức vật tư nhanh (dạng JSON)
  images         String[] // Danh sách URL hình ảnh sản phẩm
  
  minStock      Float? // Ngưỡng tồn kho tối thiểu (cảnh báo)
  location      String? // Vị trí để hàng trong kho (vd: Kệ A1)
  status        ProductStatus @default(DRAFT) // Trạng thái: Nháp (DRAFT), Đang bán (ACTIVE), Ẩn (HIDDEN)
  warranties    Warranty[] // Lịch sử bảo hành của sản phẩm này

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMoveItems   StockMoveItem[] // Lịch sử nhập/xuất kho của sản phẩm này
  stockBalances    StockBalance[] // Số dư tồn kho tại các kho
  variants         ProductVariant[] // Các phiên bản màu sắc, kích cỡ
  quoteItems       QuoteItem[] // Có trong những báo giá/đơn hàng nào
  productionOrders ProductionOrder[] // Các lệnh sản xuất của sản phẩm này
  jobSheets        JobSheet[] // Các phiếu gia công cho sản phẩm này

  @@index([orgId])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  HIDDEN
}

model ProductVariant {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh biến thể
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  productId String  @db.ObjectId // Thuộc sản phẩm chính nào
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku   String // Mã SKU riêng cho biến thể
  name  String? // Tên biến thể (vd: Màu đỏ - Size L)
  size  String? // Kích cỡ riêng
  color String? // Màu sắc riêng

  priceVnd     Float? // Giá bán riêng cho biến thể
  costPriceVnd Float? // Giá vốn riêng cho biến thể

  stockBalances    StockBalance[]
  productionOrders ProductionOrder[]
  quoteItems       QuoteItem[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([orgId, sku])
}

model Material {
  id    String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh vật tư
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  categoryId String?   @db.ObjectId // Thuộc nhóm vật tư nào
  category   Category? @relation(fields: [categoryId], references: [id])

  name     String // Tên vật tư (vd: Song mây, Keo 502)
  unit     String // Đơn vị tính (kg, mét, lít...)
  sku      String? @unique // Mã quản lý vật tư
  price    Float? // Giá nhập trung bình
  image    String? // Ảnh mẫu vật tư
  stock    Float   @default(0) // Số lượng tồn kho thực tế
  minStock Float   @default(0) // Ngưỡng báo động hết hàng
  
  supplierId String? @db.ObjectId // ID Nhà cung cấp (Liên kết chuẩn hóa)
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierName String? // (Dự phòng tên nếu không muốn tạo Supplier chi tiết)

  location String? // Vị trí lưu kho

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMoveItems StockMoveItem[] // Lịch sử nhập/xuất vật tư
  stockBalances  StockBalance[] // Số dư tồn kho vật tư

  @@index([orgId])
}

model Supplier {
  id    String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh nhà cung cấp
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  code    String? @unique // Mã NCC (vd: NCC-01)
  name    String // Tên nhà cung cấp / Công ty
  email   String? // Email liên hệ
  phone   String? // Số điện thoại
  address String? // Địa chỉ văn phòng/kho NCC
  taxId   String? // Mã số thuế NCC

  materials Material[] // Danh sách vật tư cung cấp
  debts     Debt[] // Lịch sử công nợ với NCC này

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

// ==========================================
// 4. QUẢN LÝ SẢN XUẤT (PRODUCTION)
// ==========================================

enum ProductionStatus {
  PENDING
  DOING
  DONE
  CANCELLED
}

model ProductionOrder {
  id    String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh lệnh sản xuất
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  orderNumber String @unique // Mã lệnh sản xuất (vd: SX-001)

  productId String  @db.ObjectId // Sản phẩm cần làm
  product   Product @relation(fields: [productId], references: [id])

  artisanId String? @db.ObjectId // Giao cho thợ nào
  artisan   Artisan? @relation(fields: [artisanId], references: [id])

  variantId String?         @db.ObjectId // Biến thể cụ thể (nếu có)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Float // Số lượng cần sản xuất
  status ProductionStatus @default(PENDING) // Trạng thái: Chờ (PENDING), Đang làm (DOING), Xong (DONE)

  laborCostPerUnit  Float? // Tiền công thợ cho 1 sản phẩm
  totalLaborCost    Float? // Tổng tiền công cho cả lệnh
  totalMaterialCost Float? // Tổng chi phí vật tư dự kiến
  totalShippingCost Float? // Phí vận chuyển (nếu có)
  otherCosts        Float? // Chi phí phát sinh khác
  actualTotalCost   Float? @default(0) // Tổng chi phí thực tế sau khi xong

  startDate       DateTime? // Ngày bắt đầu làm
  expectedEndDate DateTime? // Ngày dự kiến hoàn thành
  actualEndDate   DateTime? // Ngày thực tế hoàn thành
  duration        Int? // Số ngày thực hiện thực tế
  note            String? // Ghi chú kỹ thuật cho thợ

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  workers   ProductionWorker[]
  materials ProductionMaterial[]
  jobSheets JobSheet[] // Các phiếu gia công chi tiết từ lệnh này

  @@index([orgId])
}

model ProductionWorker {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId   String   @db.ObjectId
  order     ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artisanId String   @db.ObjectId
  artisan   Artisan  @relation(fields: [artisanId], references: [id])

  @@unique([orderId, artisanId])
}

model ProductionMaterial {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String   @db.ObjectId
  order      ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  materialId String   @db.ObjectId
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Float
  unitCost   Float?

  @@index([orderId])
}

// ==========================================
// 5. QUẢN LÝ KHO (INVENTORY)
// ==========================================

model Warehouse {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh kho
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  code    String // Mã kho (vd: KHO-01)
  name    String // Tên kho (vd: Kho thành phẩm)
  address String? // Địa chỉ kho
  note    String? // Ghi chú kho

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMoves    StockMove[] // Danh sách các lần nhập/xuất tại kho này
  stockBalances StockBalance[] // Số dư tồn kho tại kho này
  deliveries    Delivery[] // Danh sách phiếu giao hàng từ kho này

  @@unique([orgId, code])
}

enum StockMoveType {
  IN
  OUT
  ADJUST
}

model StockMove {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh phiếu kho
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  warehouseId String    @db.ObjectId // Kho thực hiện
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  type    StockMoveType // Loại: Nhập (IN), Xuất (OUT), Điều chỉnh (ADJUST)
  note    String? // Ghi chú phiếu kho (vd: Nhập hàng từ NCC A)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items StockMoveItem[] // Chi tiết các mặt hàng trong phiếu
}

model StockMoveItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh dòng phiếu kho
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  stockMoveId String    @db.ObjectId // Thuộc phiếu kho nào
  stockMove   StockMove @relation(fields: [stockMoveId], references: [id], onDelete: Cascade)

  productId String?  @db.ObjectId // Là sản phẩm?
  product   Product? @relation(fields: [productId], references: [id])

  materialId String?   @db.ObjectId // Là vật tư?
  material   Material? @relation(fields: [materialId], references: [id])

  qty      Float // Số lượng nhập/xuất
  unitCost Float? // Giá trị tại thời điểm nhập/xuất

  @@index([stockMoveId])
}

model StockBalance {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh số dư kho
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  warehouseId String    @db.ObjectId // Tại kho nào
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  productId String?  @db.ObjectId // ID sản phẩm
  product   Product? @relation(fields: [productId], references: [id])

  variantId String?         @db.ObjectId // ID biến thể (nếu có)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  materialId String?   @db.ObjectId // ID vật tư
  material   Material? @relation(fields: [materialId], references: [id])

  qty Float @default(0) // Số lượng tồn thực tế

  updatedAt DateTime @updatedAt // Ngày cập nhật tồn cuối

  @@unique([warehouseId, productId, variantId, materialId])
}

// ==========================================
// 6. KINH DOANH & CÔNG NỢ (SALES & DEBTS)
// ==========================================

enum CustomerGroup {
  RETAIL
  WHOLESALE
  AGENCY
}

model Customer {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh khách hàng
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  code        String?  @unique // Mã khách hàng (vd: KH-001)
  name        String // Tên khách hàng/Công ty
  email       String? // Email liên hệ
  phone       String? // Số điện thoại
  address     String? // Địa chỉ giao hàng/trụ sở
  taxId       String? // Mã số thuế (nếu có)
  
  zalo        String? // Link/SĐT Zalo
  facebook    String? // Link Facebook
  birthday    DateTime? // Ngày sinh nhật khách
  groupName   CustomerGroup @default(RETAIL) // Nhóm: Lẻ (RETAIL), Sỉ (WHOLESALE), Đại lý (AGENCY)
  totalSpent  Float    @default(0) // Tổng tiền khách đã mua tích lũy
  currentDebt Float    @default(0) // Công nợ hiện tại khách nợ xưởng

  quotes          Quote[] // Lịch sử đơn hàng/báo giá
  debts           Debt[] // Lịch sử công nợ chi tiết

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  warranties      Warranty[] // Lịch sử bảo hành & sửa chữa
}

enum QuoteStatus {
  DRAFT
  CONFIRMED
  DELIVERING
  DONE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK
  DEBT
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Quote {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh đơn hàng/báo giá
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  number   String      @unique // Số đơn hàng (vd: DH-2024001)
  status   QuoteStatus @default(DRAFT) // Trạng thái đơn: Nháp, Xác nhận, Đang giao, Xong, Hủy

  customerId String?   @db.ObjectId // Khách hàng mua
  customer   Customer? @relation(fields: [customerId], references: [id])

  items      QuoteItem[] // Danh sách mặt hàng mua
  deliveries Delivery[] // Lịch sử các lần giao hàng cho đơn này

  subTotal      Float @default(0) // Tổng tiền hàng (trước giảm giá)
  discount      Float @default(0) // Số tiền giảm giá cho đơn
  shippingFee   Float @default(0) // Phí vận chuyển báo khách
  grandTotal    Float @default(0) // Tổng thanh toán cuối cùng
  
  paymentMethod PaymentMethod @default(CASH) // Phương thức: Tiền mặt (CASH), Chuyển khoản (BANK), Ghi nợ (DEBT)
  paymentStatus PaymentStatus @default(UNPAID) // Trạng thái: Chưa thanh (UNPAID), Một phần (PARTIAL), Đã xong (PAID)
  expiryDate    DateTime? // Ngày hết hạn hiệu lực của báo giá
  
  notes      String? // Ghi chú đơn hàng

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model QuoteItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh dòng đơn hàng
  quoteId String @db.ObjectId // Thuộc đơn nào
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId String?  @db.ObjectId // ID sản phẩm
  product   Product? @relation(fields: [productId], references: [id])

  variantId String?         @db.ObjectId // ID biến thể
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity  Float // Số lượng mua
  unitPrice Float // Đơn giá bán tại thời điểm đó
  discount  Float @default(0) // Giảm giá riêng cho dòng này
  lineTotal Float // Thành tiền sau giảm giá

  // Snapshot fields for easier grouping and historical accuracy
  sku       String?
  nameVi    String?
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  DELIVERED
}

model Delivery {
  id String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh phiếu giao hàng
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  quoteId String @db.ObjectId // Giao cho đơn hàng nào
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  carrier        String? // Đơn vị vận chuyển (Viettel, GHTK, Xe nhà...)
  vehicleType    String? // Loại xe (Xe tải, xe khách, xe máy...)
  vehicleNumber  String? // Biển số xe giao hàng
  driverName     String? // Tên tài xế
  driverPhone    String? // Số điện thoại tài xế
  trackingNumber String? // Mã vận đơn (tra cứu hành trình)
  shippingCost   Float? // Chi phí thực tế phải trả cho nhà xe
  receiptImage   String? // Ảnh phiếu ký nhận/biên bản giao hàng
  status         DeliveryStatus @default(PENDING) // Trạng thái: Chờ (PENDING), Đã lấy hàng (PICKED_UP), Đã giao (DELIVERED)
  
  warehouseId String?        @db.ObjectId // Xuất hàng từ kho nào
  warehouse   Warehouse?     @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DebtReferenceType {
  CUSTOMER
  ARTISAN
  SUPPLIER
}

enum DebtStatus {
  UNPAID
  PARTIAL
  PAID_OFF
}

model Debt {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh công nợ
  orgId        String     @db.ObjectId // ID xưởng
  org          Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  type          String // Loại nợ: Phải thu (RECEIVABLE) / Phải trả (PAYABLE)
  referenceType DebtReferenceType @default(CUSTOMER) // Đối tượng nợ: Khách hàng, Thợ, hoặc Nhà cung cấp
  referenceId   String?    @db.ObjectId // ID cụ thể của đối tượng nợ (link tới bảng tương ứng)

  // Liên kết tùy chọn tới các bảng
  customerId   String?    @db.ObjectId
  customer     Customer?  @relation(fields: [customerId], references: [id])
  artisanId    String?    @db.ObjectId
  artisan      Artisan?   @relation(fields: [artisanId], references: [id])
  supplierId   String?    @db.ObjectId
  supplier     Supplier?  @relation(fields: [supplierId], references: [id])
  
  amount       Float // Tổng số tiền nợ phát sinh
  paidAmount   Float      @default(0) // Số tiền đã trả/thu được
  dueDate      DateTime // Hạn chót thanh toán
  status       DebtStatus @default(UNPAID) // Trạng thái: Chưa trả (UNPAID), Một phần (PARTIAL), Xong (PAID_OFF)
  note         String? // Ghi chú (vd: Nợ đơn DH-001)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum ExpenseCategory {
  UTILITY
  EQUIPMENT
  SALARY
  MARKETING
  OTHER
}

model Expense {
  id    String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh phiếu chi
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  title    String // Nội dung chi (vd: Trả tiền điện, Mua keo)
  category ExpenseCategory @default(OTHER) // Phân loại chi phí
  amount   Float // Số tiền chi ra
  paymentMethod String?   @default("CASH") // Hình thức chi: Tiền mặt (CASH), Chuyển khoản (BANK)
  receiptImage  String? // Ảnh chụp biên lai/Hóa đơn chi
  expenseDate   DateTime @default(now()) // Ngày thực tế chi tiền
  
  createdBy     String?   @db.ObjectId // Người tạo phiếu chi
  creator       User?     @relation("ExpenseCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 7. HỆ THỐNG (SYSTEM)
// ==========================================

model Notification {
  id    String @id @default(auto()) @map("_id") @db.ObjectId // Mã định danh thông báo
  orgId String @db.ObjectId // ID xưởng
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  title   String // Tiêu đề thông báo
  message String // Nội dung chi tiết thông báo
  isRead  Boolean          @default(false) // Đã đọc chưa
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId // Liên kết tài khoản ngoại vi
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId // Phiên đăng nhập
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId // Các báo cáo đã lưu
  orgId       String     @db.ObjectId
  org         Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title       String // Tên báo cáo
  data        Json // Dữ liệu báo cáo (dạng JSON)
  createdAt   DateTime   @default(now())
}

model Counter {
  id      String   @id @map("_id") // Bộ đếm để tự tăng mã (vd: DH-001)
  seq     Int
  updated DateTime @default(now())
}

// ==========================================
// 7. QUẢN LÝ DỊCH VỤ SAU BÁN HÀNG (WARRANTY)
// ==========================================

enum WarrantyStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
}

model Warranty {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  orgId     String   @db.ObjectId
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  customerId String?  @db.ObjectId
  customer   Customer? @relation(fields: [customerId], references: [id])
  
  productId  String?  @db.ObjectId
  product    Product? @relation(fields: [productId], references: [id])
  
  status     WarrantyStatus @default(PENDING)
  issue      String   // Nội dung lỗi/yêu cầu sửa chữa
  note       String?  // Ghi chú quá trình xử lý
  
  receivedDate DateTime @default(now())
  returnDate   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

// ==========================================
// 8. QUẢN LÝ SẢN XUẤT CHI TIẾT (JOB SHEETS & PROGRESS)
// ==========================================

enum JobSheetStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model JobSheet {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  orgId String @db.ObjectId
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  orderId String? @db.ObjectId
  order   ProductionOrder? @relation(fields: [orderId], references: [id])
  
  artisanId String @db.ObjectId
  artisan   Artisan @relation(fields: [artisanId], references: [id])
  
  productId String @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])
  
  quantity Int // Số lượng giao cho thợ này
  completedQuantity Int @default(0) // Số lượng thợ đã làm xong
  
  unitPrice Float // Đơn giá trả cho thợ
  totalAmount Float // Tổng tiền dự kiến (quantity * unitPrice)
  
  status JobSheetStatus @default(OPEN)
  
  startDate DateTime @default(now())
  endDate DateTime?
  
  progress ProductionProgress[] // Lịch sử báo cáo hàng ngày
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model ProductionProgress {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  orgId String @db.ObjectId
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  
  jobId String @db.ObjectId
  job   JobSheet @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  quantity Int // Số lượng làm được hôm nay
  note String?
  
  createdAt DateTime @default(now())

  @@index([orgId])
}
